{
  "manifest_version": 3,
  "name": "PaySlip — Indian Payroll & Salary Slip Calculator",
  "version": "1.4.0",
  "description": "Indian salary & payslip calculator — PF, ESI, TDS, professional PDF payslips, bulk export & annual reports. Private & local-first.",
  "minimum_chrome_version": "100",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.lemonsqueezy.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'"
  }
}
