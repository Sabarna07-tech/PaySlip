{
  "name": "payslip-mini-payroll-calculator",
  "version": "1.4.1",
  "private": true,
  "description": "Indian salary & payslip calculator Chrome extension with PF/ESI/TDS, PDF payslips, bulk export and annual reports.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.web.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit": "npm audit --omit=dev",
    "clean": "node scripts/clean.cjs",
    "build": "npm run typecheck && vite build",
    "build:web": "npm run typecheck && vite build --config vite.web.config.ts",
    "build:all": "npm run build && vite build --config vite.web.config.ts",
    "zip": "node scripts/zip-dist.cjs",
    "preflight": "npm run audit && npm run test && npm run build && npm run zip",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.web.config.ts"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.27",
    "@types/chrome": "^0.0.279",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0"
    }
  }
}
